generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  image     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  contacts  Contact[]  @relation("UserContacts")
  reminders Reminder[]
}

model Contact {
  id                String        @id @default(cuid())
  ownerId           String
  name              String
  category          Category      @default(FRIEND)
  phone             String?
  email             String?
  description       String?       // Merged from Node
  groups            String[]      @default([])       // Merged from Node
  metadata          Json?         // Merged from Node
  relationshipId    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt @default(now()) // Added default to handle existing rows if any, though usually @updatedAt handles updates. Using @default(now()) for new rows.
  lastInteractionAt DateTime?
  lastPlatform      Platform?
  commonPlatform    Platform?
  owner             User          @relation("UserContacts", fields: [ownerId], references: [id])
  relationship      Relationship? @relation(fields: [relationshipId], references: [id])
  interactions      Interaction[]
  Reminder          Reminder[]
  outgoing          Link[]        @relation("from")
  incoming          Link[]        @relation("to")
}

model Relationship {
  id         String    @id @default(cuid())
  contactAId String
  contactBId String
  type       String
  notes      String?
  createdAt  DateTime  @default(now())
  Contact    Contact[]
}

model Interaction {
  id        String    @id @default(cuid())
  type      String
  content   String?
  platform  Platform  @default(OTHER)
  date      DateTime  @default(now())
  contacts  Contact[]
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  message     String
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  contact     Contact? @relation(fields: [contactId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

enum Category {
  FRIEND
  FAMILY
  WORK
  MUTUAL
  OTHER
}

enum Platform {
  SMS
  CALL
  EMAIL
  INSTAGRAM
  DISCORD
  WHATSAPP
  FACEBOOK
  LINKEDIN
  SNAPCHAT
  TELEGRAM
  IN_PERSON
  OTHER
}

// Node / Link graph models for network visualization and relationships
// Node model removed. Merged into Contact.

model Link {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      Contact  @relation("from", fields: [fromId], references: [id])
  to        Contact  @relation("to", fields: [toId], references: [id])
  label     String?
  weight    Float?   @default(1.0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

