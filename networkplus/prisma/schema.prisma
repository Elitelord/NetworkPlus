generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  image     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  contacts  Contact[]  @relation("UserContacts")
  reminders Reminder[]
  Node      Node[]
}

model Contact {
  id                String        @id @default(cuid())
  ownerId           String
  name              String
  category          Category      @default(FRIEND)
  phone             String?
  email             String?
  relationshipId    String?
  createdAt         DateTime      @default(now())
  lastInteractionAt DateTime?
  lastPlatform      Platform?
  commonPlatform    Platform?
  owner             User          @relation("UserContacts", fields: [ownerId], references: [id])
  relationship      Relationship? @relation(fields: [relationshipId], references: [id])
  interactions      Interaction[]
  Reminder          Reminder[]
}

model Relationship {
  id         String    @id @default(cuid())
  contactAId String
  contactBId String
  type       String
  notes      String?
  createdAt  DateTime  @default(now())
  Contact    Contact[]
}

model Interaction {
  id        String   @id @default(cuid())
  contactId String
  type      String
  content   String?
  platform  Platform @default(OTHER)
  date      DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id])
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  message     String
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  contact     Contact? @relation(fields: [contactId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

enum Category {
  FRIEND
  FAMILY
  WORK
  MUTUAL
  OTHER
}

enum Platform {
  SMS
  CALL
  EMAIL
  INSTAGRAM
  DISCORD
  WHATSAPP
  FACEBOOK
  LINKEDIN
  SNAPCHAT
  TELEGRAM
  IN_PERSON
  OTHER
}

// Node / Link graph models for network visualization and relationships
model Node {
  id          String   @id @default(cuid())
  title       String
  description String?
  group       String?
  metadata    Json?
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  outgoing    Link[]   @relation("from")
  incoming    Link[]   @relation("to")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Link {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      Node     @relation("from", fields: [fromId], references: [id])
  to        Node     @relation("to", fields: [toId], references: [id])
  label     String?
  weight    Float?   @default(1.0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

