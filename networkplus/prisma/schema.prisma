generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                String     @id @default(cuid())
  name                              String
  email                             String     @unique
  image                             String?
  createdAt                         DateTime   @default(now())
  updatedAt                         DateTime   @updatedAt
  emailVerified                     DateTime?
  hashedPassword                    String?
  fcmToken                          String?
  notificationTime                  String?
  notificationsEnabled              Boolean    @default(false)
  catchUpCategories                 String[]   @default([])
  catchUpContactIds                 String[]   @default([])
  catchUpDays                       Int[]      @default([])
  catchUpGroups                     String[]   @default([])
  lastCatchUpSentAt                 DateTime?
  filterReachOutByPreferences       Boolean    @default(false)
  groupTypeOverrides                Json?
  groups                            String[]   @default([])
  inferenceIncludePriorAffiliations Boolean    @default(false)
  hasCompletedOnboarding            Boolean    @default(false)
  hasCompletedTour                  Boolean    @default(false)
  useCase                           String?
  industryField                     String?
  primaryGoal                       String?
  accounts                          Account[]
  contacts                          Contact[]  @relation("UserContacts")
  reminders                         Reminder[]
  sessions                          Session[]
  recommendations                   Recommendation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contact {
  id                         String        @id @default(cuid())
  ownerId                    String
  name                       String
  category                   Category      @default(FRIEND)
  phone                      String?
  email                      String?
  instagram                  String?
  relationshipId             String?
  createdAt                  DateTime      @default(now())
  lastInteractionAt          DateTime?
  lastPlatform               Platform?
  commonPlatform             Platform?
  description                String?
  groups                     String[]      @default([])
  metadata                   Json?
  updatedAt                  DateTime      @default(now()) @updatedAt
  strengthScore              Float         @default(0)
  monthsKnown                Int           @default(0)
  estimatedFrequencyCadence  String?
  estimatedFrequencyCount    Int?
  estimatedFrequencyPlatform Platform?
  estimatedFrequencyIsAuto   Boolean       @default(true)
  profile                    Json?
  owner                      User          @relation("UserContacts", fields: [ownerId], references: [id])
  relationship               Relationship? @relation(fields: [relationshipId], references: [id])
  outgoing                   Link[]        @relation("from")
  incoming                   Link[]        @relation("to")
  Reminder                   Reminder[]
  interactions               Interaction[] @relation("ContactToInteraction")
  recommendations            Recommendation[]

  @@index([ownerId])
}

model Relationship {
  id         String    @id @default(cuid())
  contactAId String
  contactBId String
  type       String
  notes      String?
  createdAt  DateTime  @default(now())
  Contact    Contact[]

  @@index([contactAId])
  @@index([contactBId])
}

model Interaction {
  id                  String        @id @default(cuid())
  type                String
  content             String?
  platform            Platform      @default(OTHER)
  date                DateTime      @default(now())
  directionSummary    String?
  durationSeconds     Int?
  endTime             DateTime      @default(now())
  messageCount        Int?
  metadata            Json?
  rawMessageCount     Int?
  startTime           DateTime      @default(now())
  threadId            String?
  calendarEventId     String?
  isRecurring         Boolean       @default(false)
  parentInteractionId String?
  recurringDaysOfWeek Int[]         @default([])
  recurringEndDate    DateTime?
  recurringType       String?
  recurringInterval   Int?          @default(1)
  parentInteraction   Interaction?  @relation("RecurringInstances", fields: [parentInteractionId], references: [id])
  recurringInstances  Interaction[] @relation("RecurringInstances")
  contacts            Contact[]     @relation("ContactToInteraction")

  @@index([parentInteractionId])
  @@index([threadId])
  @@index([calendarEventId])
  @@index([date])
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  message     String
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  contact     Contact? @relation(fields: [contactId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([contactId])
}

model Recommendation {
  id          String   @id @default(cuid())
  userId      String
  contactId   String
  reason      String
  icebreaker  String?
  date        DateTime @default(now())
  dismissed   Boolean  @default(false)
  
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Link {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  label     String?
  weight    Float?   @default(1.0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  from      Contact  @relation("from", fields: [fromId], references: [id])
  to        Contact  @relation("to", fields: [toId], references: [id])

  @@index([fromId])
  @@index([toId])
}

enum Category {
  FRIEND
  FAMILY
  WORK
  MUTUAL
  OTHER
}

enum Platform {
  SMS
  CALL
  EMAIL
  INSTAGRAM
  DISCORD
  WHATSAPP
  FACEBOOK
  LINKEDIN
  SNAPCHAT
  TELEGRAM
  IN_PERSON
  OTHER
}
