generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                          String     @id @default(cuid())
  name                        String
  email                       String     @unique
  image                       String?
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt
  groups                      String[]   @default([])
  emailVerified               DateTime?
  hashedPassword              String?
  fcmToken                    String?
  notificationTime            String?
  notificationsEnabled        Boolean    @default(false)
  catchUpCategories           String[]   @default([])
  catchUpContactIds           String[]   @default([])
  catchUpDays                 Int[]      @default([])
  catchUpGroups               String[]   @default([])
  lastCatchUpSentAt           DateTime?
  filterReachOutByPreferences Boolean    @default(false)
  groupTypeOverrides          Json?
  accounts                    Account[]
  contacts                    Contact[]  @relation("UserContacts")
  reminders                   Reminder[]
  sessions                    Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contact {
  id                         String        @id @default(cuid())
  ownerId                    String
  name                       String
  category                   Category      @default(FRIEND)
  phone                      String?
  email                      String?
  relationshipId             String?
  createdAt                  DateTime      @default(now())
  lastInteractionAt          DateTime?
  lastPlatform               Platform?
  commonPlatform             Platform?
  description                String?
  groups                     String[]      @default([])
  metadata                   Json?
  updatedAt                  DateTime      @default(now()) @updatedAt
  strengthScore              Float         @default(0)
  monthsKnown                Int           @default(0)
  estimatedFrequencyCadence  String?
  estimatedFrequencyCount    Int?
  estimatedFrequencyPlatform Platform?
  estimatedFrequencyIsAuto   Boolean       @default(true)
  owner                      User          @relation("UserContacts", fields: [ownerId], references: [id])
  relationship               Relationship? @relation(fields: [relationshipId], references: [id])
  outgoing                   Link[]        @relation("from")
  incoming                   Link[]        @relation("to")
  Reminder                   Reminder[]
  interactions               Interaction[] @relation("ContactToInteraction")
}

model Relationship {
  id         String    @id @default(cuid())
  contactAId String
  contactBId String
  type       String
  notes      String?
  createdAt  DateTime  @default(now())
  Contact    Contact[]
}

model Interaction {
  id                  String        @id @default(cuid())
  type                String
  content             String?
  platform            Platform      @default(OTHER)
  date                DateTime      @default(now())
  directionSummary    String?
  durationSeconds     Int?
  endTime             DateTime      @default(now())
  messageCount        Int?
  metadata            Json?
  rawMessageCount     Int?
  startTime           DateTime      @default(now())
  threadId            String?
  calendarEventId     String?
  isRecurring         Boolean       @default(false)
  parentInteractionId String?
  recurringDaysOfWeek Int[]         @default([])
  recurringEndDate    DateTime?
  recurringType       String?
  recurringInterval   Int?          @default(1)
  parentInteraction   Interaction?  @relation("RecurringInstances", fields: [parentInteractionId], references: [id])
  recurringInstances  Interaction[] @relation("RecurringInstances")
  contacts            Contact[]     @relation("ContactToInteraction")
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  message     String
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  contact     Contact? @relation(fields: [contactId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Link {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  label     String?
  weight    Float?   @default(1.0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  from      Contact  @relation("from", fields: [fromId], references: [id])
  to        Contact  @relation("to", fields: [toId], references: [id])
}

enum Category {
  FRIEND
  FAMILY
  WORK
  MUTUAL
  OTHER
}

enum Platform {
  SMS
  CALL
  EMAIL
  INSTAGRAM
  DISCORD
  WHATSAPP
  FACEBOOK
  LINKEDIN
  SNAPCHAT
  TELEGRAM
  IN_PERSON
  OTHER
}
