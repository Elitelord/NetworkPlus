generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String     @id @default(cuid())
  name                 String
  email                String     @unique
  hashedPassword       String?
  image                String?
  emailVerified        DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  contacts             Contact[]  @relation("UserContacts")
  reminders            Reminder[]
  accounts             Account[]
  sessions             Session[]
  fcmToken             String?
  notificationsEnabled Boolean    @default(false)
  notificationTime     String? // Format: "HH:mm" (24h) in UTC
  catchUpDays          Int[]      @default([]) // 0=Sun, 6=Sat
  catchUpGroups        String[]   @default([])
  catchUpCategories    String[]   @default([])
  catchUpContactIds    String[]   @default([])
  filterReachOutByPreferences Boolean @default(false)
  lastCatchUpSentAt    DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contact {
  id                String        @id @default(cuid())
  ownerId           String
  name              String
  category          Category      @default(FRIEND)
  phone             String?
  email             String?
  description       String? // Merged from Node
  groups            String[]      @default([]) // Merged from Node
  metadata          Json? // Merged from Node
  relationshipId    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt // Added default to handle existing rows if any, though usually @updatedAt handles updates. Using @default(now()) for new rows.
  lastInteractionAt DateTime?
  lastPlatform      Platform?
  commonPlatform    Platform?
  strengthScore     Float         @default(0)
  monthsKnown       Int           @default(0)
  owner             User          @relation("UserContacts", fields: [ownerId], references: [id])
  relationship      Relationship? @relation(fields: [relationshipId], references: [id])
  interactions      Interaction[]
  Reminder          Reminder[]
  outgoing          Link[]        @relation("from")
  incoming          Link[]        @relation("to")
}

model Relationship {
  id         String    @id @default(cuid())
  contactAId String
  contactBId String
  type       String
  notes      String?
  createdAt  DateTime  @default(now())
  Contact    Contact[]
}

model Interaction {
  id               String    @id @default(cuid())
  type             String
  content          String?
  platform         Platform  @default(OTHER)
  date             DateTime  @default(now())
  startTime        DateTime  @default(now())
  endTime          DateTime  @default(now())
  durationSeconds  Int?
  messageCount     Int?
  directionSummary String? // INBOUND, OUTBOUND, MIXED
  rawMessageCount  Int?
  metadata         Json?
  threadId         String?
  calendarEventId  String?   // Google Calendar event ID for dedup
  contacts         Contact[]

  // Recurring interaction fields
  isRecurring          Boolean       @default(false)
  recurringType        String?       // DAILY, WEEKLY, BIWEEKLY, MONTHLY, CUSTOM
  recurringInterval    Int?          @default(1)
  recurringDaysOfWeek  Int[]         @default([]) // 0=Sun, 6=Sat
  recurringEndDate     DateTime?
  parentInteractionId  String?
  parentInteraction    Interaction?  @relation("RecurringInstances", fields: [parentInteractionId], references: [id])
  recurringInstances   Interaction[] @relation("RecurringInstances")
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  message     String
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  contact     Contact? @relation(fields: [contactId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

enum Category {
  FRIEND
  FAMILY
  WORK
  MUTUAL
  OTHER
}

enum Platform {
  SMS
  CALL
  EMAIL
  INSTAGRAM
  DISCORD
  WHATSAPP
  FACEBOOK
  LINKEDIN
  SNAPCHAT
  TELEGRAM
  IN_PERSON
  OTHER
}

// Node / Link graph models for network visualization and relationships
// Node model removed. Merged into Contact.

model Link {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      Contact  @relation("from", fields: [fromId], references: [id])
  to        Contact  @relation("to", fields: [toId], references: [id])
  label     String?
  weight    Float?   @default(1.0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
